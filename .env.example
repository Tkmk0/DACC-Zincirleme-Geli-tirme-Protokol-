# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://dacc:dacc_secret@localhost:5432/dacc?schema=public"

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ─── API Server ───────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
NODE_ENV="development"

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL="info"

# ─── Brand Engine (Dosya 2) ───────────────────────────────────
OPENAI_API_KEY="sk-..."
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIM="1536"
CHAT_MODEL="gpt-4o-mini"
RAG_TOP_K="5"
RAG_MIN_SIMILARITY="0.7"
CHUNK_SIZE_TOKENS="512"
CHUNK_OVERLAP_TOKENS="64"
